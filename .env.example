# Zomato Restaurant Recommender Configuration

# Groq API Configuration (Required for recommendation ranking & explanation)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3

# Dataset Configuration
HF_DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation
DATA_CACHE_PATH=data/restaurants.parquet

# Budget Tier Cutoffs (INR for cost for two)
# low: <= low_max
# medium: low_max < cost <= medium_max
# high: > medium_max
BUDGET_THRESHOLDS_LOW_MAX=500
BUDGET_THRESHOLDS_MEDIUM_MAX=1500

# Pipeline Configuration
MAX_CANDIDATES_FOR_LLM=20
TOP_K_RECOMMENDATIONS=5

# CORS Allowed Origins (comma-separated, no trailing slashes)
# Local dev default is pre-configured in config.py — no need to set this locally.
# In production (Railway), set this to your Vercel domain(s):
#   ALLOWED_ORIGINS=https://zomato-ai-recommender.vercel.app,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000
