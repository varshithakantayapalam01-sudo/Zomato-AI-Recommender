{
  "version": 2,
  "framework": null,
  "buildCommand": "echo 'window.RAILWAY_API_URL = \"\";' > src/ui/frontend/config.js",
  "outputDirectory": "src/ui/frontend",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://zomato-ai-recommender-production.up.railway.app/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

