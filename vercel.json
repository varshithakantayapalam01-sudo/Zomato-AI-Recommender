{
  "version": 2,
  "framework": null,
  "buildCommand": "sh -c \"printf \\\"window.RAILWAY_API_URL = '%s';\\\" \\\"$(echo -n ${RAILWAY_API_URL} | tr -d '[:space:]')\\\" > src/ui/frontend/config.js\"",
  "outputDirectory": "src/ui/frontend",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

